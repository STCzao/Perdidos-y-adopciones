# API
# En desarrollo: http://localhost:3000/api
# En producción (Vercel): /api  ← usa el proxy de vercel.json
VITE_API_URL=http://localhost:3000/api

# Seed token del backend (solo necesario para rutas de inicialización)
VITE_API_SEED_TOKEN=your_seed_token_here

# Contact form (Web3Forms)
VITE_ACCESS_KEY=your_web3forms_access_key_here

# Cloudinary (subida de imágenes)
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset
VITE_CLOUDINARY_API_KEY=your_cloudinary_api_key

# Assets — URLs de imágenes de marca (Cloudinary u otro CDN)
VITE_FAVICON_URL=https://your-cdn.com/favicon.png
VITE_NAVBAR_LOGO_URL=https://your-cdn.com/navbar-logo.png
VITE_FOOTER_IMG_URL=https://your-cdn.com/footer-image.png
VITE_DIRECT_ACCESS_ICON=https://your-cdn.com/direct-access-icon.jpg

# Fondos de secciones
VITE_ACCESS_IMG_URL=https://your-cdn.com/access-background.jpg
VITE_HOME_IMG_URL=https://your-cdn.com/home-hero.png
VITE_HOME_COLAB_IMG_URL=https://your-cdn.com/home-collaboration.png
VITE_WHATDO_IMG_URL=https://your-cdn.com/what-do-background.png
VITE_CONTACT_IMG_URL=https://your-cdn.com/contact-background.jpg
VITE_CASOS_IMG_URL=https://your-cdn.com/casos-background.jpg
VITE_MEDIA_IMG_URL=https://your-cdn.com/media-background.jpg
